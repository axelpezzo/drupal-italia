{% set has_pro = content.field_comp_pro|render|striptags|trim is not empty %}
{% set has_cons = content.field_comp_cons|render|striptags|trim is not empty %}

{% if has_pro or has_cons %}
  <div class="my-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
    {# ── Pro ──────────────────────────────────────────────────────────── #}
    {% if has_pro %}
      <div class="flex flex-col gap-4 rounded-xl border border-emerald-200 bg-emerald-50/60 p-5 dark:border-emerald-900/40 dark:bg-emerald-950/20">
        <div class="flex items-center gap-2.5">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white shadow-sm">
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="20 6 9 17 4 12" />
            </svg>
          </span>
          <span class="text-sm font-bold tracking-wide text-emerald-700 uppercase dark:text-emerald-400">Pro</span>
        </div>

        <div class="comp-list comp-list--pro prose-content text-sm leading-relaxed text-foreground">
          {{ content.field_comp_pro }}
        </div>
      </div>
    {% endif %}

    {# ── Contro ───────────────────────────────────────────────────────── #}
    {% if has_cons %}
      <div class="flex flex-col gap-4 rounded-xl border border-red-200 bg-red-50/60 p-5 dark:border-red-900/40 dark:bg-red-950/20">
        <div class="flex items-center gap-2.5">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-red-500 text-white shadow-sm">
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </span>
          <span class="text-sm font-bold tracking-wide text-red-600 uppercase dark:text-red-400">Contro</span>
        </div>

        <div class="comp-list comp-list--cons prose-content text-sm leading-relaxed text-foreground">
          {{ content.field_comp_cons }}
        </div>
      </div>
    {% endif %}
  </div>
{% endif %}
