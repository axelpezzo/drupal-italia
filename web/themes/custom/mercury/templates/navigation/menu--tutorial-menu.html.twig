{#
/**
 * Template per il menu tutorial-menu.
 * Stile sidebar con maggiore importanza visiva rispetto al blog-menu:
 * - voci più ampie con background tinto sempre visibile
 * - indicatore colore circolare a sinistra (in futuro: colore dal campo
 *   field_tutorial_topics_color del termine tassonomia associato)
 * - freccia sulla voce attiva
 */
#}
{% if items %}
  {% set current_path = path('<current>') %}
  <nav aria-label="Menu tutorial">
    <ul class="m-0 flex list-none flex-col gap-1 p-0">
      {% for item in items %}
        {% set item_path = item.url.toString %}
        {% set is_active = item.in_active_trail or item_path == current_path %}
        {% set link_classes = is_active
          ? 'flex items-center gap-3 px-4 py-3.5 bg-accent/12 font-bold text-foreground transition-all duration-200'
          : 'flex items-center gap-3 px-4 py-3.5 text-foreground/65 font-medium transition-all duration-200 hover:bg-foreground/5 hover:text-foreground'
        %}
        {% set aria_current = is_active ? 'aria-current="page"' : '' %}
        <li class="group">
          <a
            href="{{ item.url }}"
            class="{{ link_classes }}"
            {{ aria_current }}
          >
            {# Pallino colorato: usa il colore del termine tassonomia se disponibile #}
            <span
              class="h-2.5 w-2.5 shrink-0 rounded-full transition-colors duration-200 {{
                item.topic_color ? '' : (is_active ? 'bg-accent' : 'bg-foreground/20 group-hover:bg-accent/50')
              }}"
              {% if item.topic_color %}
                style="background-color: {{ item.topic_color }}"
              {% endif %}
              aria-hidden="true"
            ></span>

            <span class="flex-1 text-sm leading-snug">{{ item.title }}</span>

            {# Freccia sulla voce attiva #}
            {% if is_active %}
              <svg
                class="h-3.5 w-3.5 shrink-0 text-accent"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            {% endif %}
          </a>
        </li>
      {% endfor %}
    </ul>
  </nav>
{% endif %}
