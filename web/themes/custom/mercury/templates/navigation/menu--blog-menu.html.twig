{#
/**
 * Template per il menu blog-menu.
 * Visualizza le voci come una lista verticale stile sidebar blog,
 * evidenziando la voce attiva.
 */
#}
{% if items %}
  {% set current_path = path('<current>') %}
  <nav aria-label="Menu blog">
    <ul class="flex flex-col">
      {% for item in items %}
        {% set item_path = item.url.toString %}
        {% set is_active = item.in_active_trail or item_path == current_path %}
        <li>
          {{
            link(
              item.title,
              item.url,
              {
                class: [
                  'group flex items-center justify-between gap-3',
                  'px-4 py-3',
                  'text-sm font-medium',
                  'border-l-2 transition-all duration-200',
                  is_active
                    ? 'border-primary text-primary bg-primary/5 font-semibold'
                    : 'border-transparent text-foreground/60 hover:border-primary/40 hover:text-foreground hover:bg-foreground/4'
                ]|join(' ')
              }
            )
          }}
        </li>
      {% endfor %}
    </ul>
  </nav>
{% endif %}
