{#
/**
 * Template per events — block_4 (evento in evidenza).
 * Renderizza 1 solo evento sticky con stile prominente,
 * posizionato sotto l'hero e prima della lista eventi in page_1.
 */
#}

{% if rows %}
  <div class="bg-primary">
    <div class="container mx-auto px-4 py-8 md:py-10">
      {# Label sezione #}
      <div class="mb-5 flex items-center gap-3">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-white/20 px-3 py-1 text-xs font-bold tracking-widest text-white uppercase">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>Evento in evidenza
        </span>
        <div class="h-px flex-1 bg-white/20"></div>
      </div>

      {# Card evento — wrapper con accento visivo #}
      <div class="relative overflow-hidden">
        <div class="pl-1">
          {{ rows }}
        </div>
      </div>
    </div>
  </div>
{% endif %}
