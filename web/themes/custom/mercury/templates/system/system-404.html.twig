{#
/**
 * Template pagina 404 — Pagina non trovata.
 */
#}

{# ── Hero ─────────────────────────────────────────────────────────── #}
{{
  include(
    'mercury:hero',
    {
      variant: 'small',
      background_color: 'foreground',
      text_color: 'light',
      content_align: 'left',
      heading_level: 1,
      heading_text: '404 — Pagina non trovata'
    },
    with_context: false
  )
}}

{# ── Body ─────────────────────────────────────────────────────────── #}
<div class="container mx-auto px-4 py-16 md:py-24">
  <div class="mx-auto max-w-2xl text-center">
    <p class="mb-4 text-6xl font-extrabold text-foreground/10 select-none">404</p>
    <h2 class="mb-4 text-2xl font-bold text-foreground">
      Questa pagina non esiste
    </h2>
    <p class="mb-10 text-lg text-foreground/60">
      La pagina che stai cercando potrebbe essere stata spostata, rinominata o rimossa.
      Controlla l'indirizzo digitato oppure torna alla homepage per trovare quello che cerchi.
    </p>
    {{
      include(
        'mercury:button',
        {
          variant: 'primary',
          size: 'large',
          label: 'Torna alla homepage',
          href: '/',
          icon: 'arrow-left',
          icon_first: true
        },
        with_context: false
      )
    }}
  </div>
</div>
